# FINC Tools 环境配置模板
# 复制此文件为 .env 并根据实际情况修改配置
# 注意: .env 已在 .gitignore 中，不会被提交到 git

# 数据库配置
DATABASE_URL="mysql://username:password@host:port/database"

# Redis配置
REDIS_URL="redis://username:password@host:port/db"

# JWT配置
JWT_SECRET="your-jwt-secret-here"

# 微信登录配置
WECHAT_APP_ID="your-wechat-app-id"
WECHAT_APP_SECRET="your-wechat-app-secret"
WECHAT_REDIRECT_URI="https://your-domain.com/api/auth/wechat/callback"

# 微信支付配置
WECHAT_PAY_APP_ID="your-wechat-pay-app-id"
WECHAT_PAY_MERCHANT_ID="your-merchant-id"
WECHAT_PAY_API_KEY="your-merchant-api-key"
WECHAT_PAY_CERT_PATH="/path/to/apiclient_cert.pem"
WECHAT_PAY_KEY_PATH="/path/to/apiclient_key.pem"
WECHAT_PAY_NOTIFY_URL="https://your-domain.com/api/payment/callback"

# 微信支付V3 API配置
WECHAT_PAY_MERCHANT_CERTIFICATE_SERIAL="your-certificate-serial"
WECHAT_PAY_PLATFORM_PUBLIC_KEY_ID="your-platform-key-id"
WECHAT_PAY_PLATFORM_PUBLIC_KEY_PATH="/path/to/platform-cert.pem"

# 雪球API配置
XUEQIU_COOKIE="your-xueqiu-cookie"

# OpenAI-compatible AI 配置
OPENAI_API_KEY="your-openai-api-key"
OPENAI_BASE_URL="https://api.openai.com/v1"
OPENAI_MODEL="gpt-4o-mini"

# 财报智能体配置
FINANCIAL_AI_AGENT_URL="http://your-ai-agent-url/chat"
NEXT_PUBLIC_FINANCIAL_AI_AGENT_URL="http://your-ai-agent-url/chat"

# 管理员初始化配置
ADMIN_USERNAME="admin"
ADMIN_PASSWORD="your-admin-password"
ADMIN_AUTH_KEY="your-admin-auth-key"

# 应用环境配置
NODE_ENV="production"
NEXTAUTH_URL="http://0.0.0.0:3000"

# 站点 URL（用于 SEO 标签，生产环境设为实际域名）
NEXT_PUBLIC_SITE_URL="https://your-domain.com"

# 百度统计（可选）
# NEXT_PUBLIC_TALLY_URL="https://hm.baidu.com/hm.js?your-baidu-tracking-id"

# 初始化选项
INIT_DATABASE=true
INIT_ADMIN=true
CHECK_EXPIRED=true

# Next.js 配置
NEXT_TELEMETRY_DISABLED=1
